  "header": [
    {
      "name": "pinch pleat",
      "price": "60",
      "fullness": "200%",
      "image": "//luxdrape.com/cdn/shop/files/pinch.jpg?crop=center&height=108&v=1764830513&width=108",
      "description": "Classic double-finger design with permanent sewn-in pleats for a luxurious, gathered look. Timeless and elegant, it works perfectly with tracks or poles with rings."
    },
    {
      "name": "tailor pleat",
      "price": "60",
      "fullness": "200%",
      "image": "//luxdrape.com/cdn/shop/files/Tailor_Pleat.jpg?crop=center&height=108&v=1764832712&width=108",
      "description": "Modern streamlined look with sophisticated, precisely spaced pleats for a structured drape. Delivers a crisp and professional aesthetic for contemporary and minimalist interiors."
    },
    {
      "name": "triple pleat",
      "price": "75",
      "fullness": "230% - 250%",
      "image": "//luxdrape.com/cdn/shop/files/Triple_Pleat.jpg?crop=center&height=108&v=1764831191&width=108",
      "description": "Three-finger pinch for maximum fullness and a high-end, voluminous finish. Creates a grand, formal appearance that is the gold standard for traditional spaces."
    },
    {
      "name": "inverted box pleat",
      "price": "70",
      "fullness": "200%",
      "image": "//luxdrape.com/cdn/shop/files/Inverted.jpg?crop=center&height=108&v=1764833179&width=108",
      "description": "Symmetrical folds that create a smooth, flat surface for a neat and tailored profile. A minimalist choice that highlights fabric patterns with architectural precision."
    },
    {
      "name": "pinch pleat with back tab",
      "price": "70",
      "fullness": "200%",
      "image": "//luxdrape.com/cdn/shop/files/pinch_with_back_tab.jpg?crop=center&height=108&v=1764834705&width=108",
      "description": "Traditional pinch pleats combined with back tabs for versatile, hardware-free hanging. A clean and adaptable solution that offers two distinct hanging styles."
    },
    {
      "name": "goblet pleat",
      "price": "70",
      "fullness": "230%",
      "image": "//luxdrape.com/cdn/shop/files/Goblet.png?crop=center&height=108&v=1764836058&width=108",
      "description": "Deep, wine-glass-shaped pleats that provide a dramatic and architectural silhouette. Ideal for formal dining or living rooms seeking a regal and decorative touch."
    },
    {
      "name": "pencil pleat",
      "price": "75",
      "fullness": "220%",
      "image": "//luxdrape.com/cdn/shop/files/pencil.jpg?crop=center&height=108&v=1764835299&width=108",
      "description": "Tightly gathered uniform folds that resemble a row of pencils for a soft, textured look. A delicate and casual-chic style that pairs beautifully with lightweight linen fabrics."
    }
